# The Anki fork is tracked in its own repo: github.com/graceyan212/anki
anki/

# Large packaged desktop build output (regenerable)
*.dmg

# Rust build cache (~2.9GB, regenerable via the build script)
bridge/anki-bridge-rs/target/

# macOS / Xcode cruft
.DS_Store
**/xcuserdata/
**/*.xcuserstate
**/DerivedData/

# Visual brainstorming companion (superpowers)
.superpowers/

# Claude Code local config / worktrees
.claude/

# Python bytecode cache (from running content/tools/*.py)
__pycache__/
*.pyc

# Demo presenter script — kept local, not part of the submission repo
docs/DEMO_SCRIPT.md
